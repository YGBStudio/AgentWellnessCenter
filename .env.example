# Local development can omit JWT_SECRET and use the built-in demo secret.
# Cloudflare Workers preview and production must define a strong JWT_SECRET secret.
JWT_SECRET=replace-with-a-long-random-secret

# Demo mode resets seeded data after demo sessions. Keep false in production
# unless the deployment is intentionally disposable.
DEMO_MODE=false

# Cloudflare Workers deployments use the D1 binding named DB.
DATABASE_DRIVER=d1

# Local Wrangler can use the development JWT secret. Cloudflare preview and
# production set this to true in wrangler.toml and must provide JWT_SECRET.
REQUIRE_JWT_SECRET=false

# Optional for Wrangler commands that talk to your Cloudflare account.
CLOUDFLARE_ACCOUNT_ID=
